rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // User's private subcollections
      match /questions/{qId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /exams/{examId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /practiceHistory/{hId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /examHistory/{hId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Shared exams - anyone can read, only owner can create/delete
    match /sharedExams/{shareCode} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && resource.data.ownerId == request.auth.uid;

      // Attempts - anyone can create (immutable), anyone can read
      match /attempts/{attemptId} {
        allow read: if true;
        allow create: if true;
      }
    }
  }
}
